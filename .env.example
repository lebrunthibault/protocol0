# Local dev overrides. Copy to `.env` (gitignored) and tweak as needed.
# `.env` is read by scripts/up.py (`make up`); nothing here is shipped.

# Port for the Vue dev server (vite, live-reload) started by `make up`.
# Default is 5173. Change it if another project already holds 5173 on your
# machine: vite is launched with --strictPort, so it uses exactly this port
# (or fails clearly) rather than silently sharing a busy one.
FRONTEND_PORT=5173
